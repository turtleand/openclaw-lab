---
import '../styles/global.css';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'Turtleand OpenClaw - Open-source AI agent documentation and tutorials',
  canonicalURL,
  ogImage = '/social-card.png',
  ogType = 'website',
} = Astro.props;
const fullTitle = `${title} | Turtleand OpenClaw`;
const resolvedCanonicalURL = canonicalURL ?? new URL(Astro.url.pathname, Astro.site).href;
const resolvedOgImage = new URL(ogImage, resolvedCanonicalURL).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={resolvedCanonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Turtleand OpenClaw Lab" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={resolvedCanonicalURL} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <meta name="theme-color" content="#0f172a" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Turtleand OpenClaw Lab",
      "description": "Practical setup guides for the OpenClaw AI assistant platform",
      "author": { "@type": "Person", "name": "Turtleand", "url": "https://turtleand.com" },
      "url": "https://openclaw.turtleand.com"
    })} />

    <!-- Theme initialization (prevent flash) -->
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme');
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="flex flex-col min-h-screen">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- Theme toggle script -->
    <script is:inline>
      function initThemeToggle() {
        const toggle = document.getElementById('theme-toggle');
        if (!toggle) return;

        toggle.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
      }

      // Run on initial load and after view transitions
      initThemeToggle();
      document.addEventListener('astro:after-swap', initThemeToggle);
    </script>
  </body>
</html>
